# --- X Layer Data API (required) ---
# OKX API credentials with X Layer Data API access. The x402 facilitator
# reuses these same credentials to settle payments.
XLAYER_API_KEY=
XLAYER_SECRET_KEY=
XLAYER_PASSPHRASE=

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Performance ---
# Metrics cache TTL in ms. Absorbs bursts (e.g. compare_wallets) without
# re-fetching a wallet's ~12 upstream calls. Set 0 to disable.
PROFILE_CACHE_TTL_MS=120000

# --- Attestations (optional) ---
# Signing key for result attestations (identity only, never holds funds).
# Unset = a fresh key is generated each boot (signer address changes).
ATTEST_PRIVATE_KEY=

# --- Risk screen (optional) ---
# Extra known-malicious addresses for screen_wallet's blocklist check,
# comma-separated. Merged with the verified in-code seed at startup.
BLOCKLIST_ADDRESSES=

# --- AI roast layer (optional) ---
# Without this, personality.ts falls back to a deterministic summary.
SUMOPOD_API_KEY=

# --- x402 payment gate (optional) ---
# off | on. When on, tools/call past the free quota returns HTTP 402.
X402_MODE=off
# Address that receives settled USDT0. Required when X402_MODE=on.
X402_PAY_TO=
X402_PRICE_USD=0.05
X402_FREE_DAILY=20
