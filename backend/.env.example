# --- X Layer Data API (required) ---
# OKX API credentials with X Layer Data API access. The x402 facilitator
# reuses these same credentials to settle payments.
XLAYER_API_KEY=
XLAYER_SECRET_KEY=
XLAYER_PASSPHRASE=

# --- Server ---
PORT=3001
NODE_ENV=development

# --- AI roast layer (optional) ---
# Without this, personality.ts falls back to a deterministic summary.
SUMOPOD_API_KEY=

# --- x402 payment gate (optional) ---
# off | on. When on, tools/call past the free quota returns HTTP 402.
X402_MODE=off
# Address that receives settled USDT0. Required when X402_MODE=on.
X402_PAY_TO=
X402_PRICE_USD=0.05
X402_FREE_DAILY=20
